STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# WebSocket Server
WS_SERVER_URL=ws://localhost:3001
NEXT_PUBLIC_WS_SERVER_URL=ws://localhost:3001

# Sentry (optional)
